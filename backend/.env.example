# ──────────────────────────────────────────────────────────────────────────────
# VAYU-DRISHTI Backend — Environment Variable Template
#
# Copy this file to .env and fill in all required values before running locally.
# NEVER commit the .env file — it contains secrets.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your local values
#
# Required variables have no default and MUST be set.
# Optional variables show their default value.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=VAYU-DRISHTI
APP_VERSION=0.1.0
APP_DESCRIPTION=Air quality monitoring and geospatial analytics platform.

# Deployment environment. Accepted: development | staging | production
ENVIRONMENT=development

# Set to true only in local development. MUST be false in production.
DEBUG=true

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Number of uvicorn worker processes. For development, 1 is sufficient.
# In production, set to (2 * CPU_CORES) + 1.
WORKERS=1

# ── Security ───────────────────────────────────────────────────────────────────
# REQUIRED — Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters. Rotate periodically in production.
SECRET_KEY=

# Comma-separated list of allowed CORS origins.
# In production, restrict to your frontend domain only.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── PostgreSQL Database ────────────────────────────────────────────────────────
# Host where PostgreSQL is running. Use 'db' when running with docker-compose.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=vayu
# REQUIRED — Password for the database user.
POSTGRES_PASSWORD=
POSTGRES_DB=vayu_drishti

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level. Accepted: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format. Use 'console' for human-readable local development.
# Use 'json' in staging/production for log aggregators (Datadog, Loki, CloudWatch).
LOG_FORMAT=console

# ── API ────────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── Startup ────────────────────────────────────────────────────────────────────
# Set to 'true' to run 'alembic upgrade head' automatically before the API server
# starts. Useful for single-container deployments and docker compose environments.
# For production Kubernetes, use a dedicated init-container instead.
RUN_MIGRATIONS=false

# ── ML / Inference (Future — Day 4+) ──────────────────────────────────────────
# Absolute path to the trained ML model artifact.
# Leave empty until ML module is implemented.
ML_MODEL_PATH=
ENABLE_ML_ENDPOINTS=false
